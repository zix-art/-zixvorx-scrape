{
  "name": "@zxvorx/scrape",
  "version": "2.2.0",
  "publishConfig": {
    "access": "public"
  },
  "description": "Kumpulan scraper/AI endpoint wrapper, auto-loaded dari folder src/lib",
  "main": "./src/index.js",
  "module": "./src/index.mjs",
  "bin": {
    "zx-scrape": "./bin/cli.js"
  },
  "exports": {
    ".": {
      "require": "./src/index.js",
      "import": "./src/index.mjs"
    }
  },
  "scripts": {
    "build": "node scripts/generate-esm.js",
    "prepare": "npm run build",
    "test": "node --test"
  },
  "files": [
    "src",
    "scripts",
    "bin"
  ],
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "cheerio": "^1.2.0"
  }
}
